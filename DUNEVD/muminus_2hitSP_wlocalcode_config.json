{
  "workflow": {
    "description": "mpvmpr gen->reco 2 hit",
    "monte_carlo": 20
  },

  "defaults": {
    "repo": "SFBayLaser/dune-justin",
    "ref": "main",
    "lifetime_days": 4,
    "max_distance": 60,
    "dunesw_version": "v10_21_00d00",
    "limit_sites": false,
    "fhicl_files": "https://raw.githubusercontent.com/SFBayLaser/dune-justin/main/bundles/fhicl_vd_bundle.tgz",
    "tarfile_dir": "/cvmfs/fifeuser3.opensciencegrid.org/sw/dune/ad2c85645bc5c1f2de72b5b91da6eebd67109cdb"
  },

  "stages": [
    {
      "id": 1,
      "jobscript": "MCJobSubmission/gen.jobscript",
      "wall_seconds": 14400,
      "rss_mib": 8000,
      "env": {
        "NEVENTS": "400",
        "RUN_BASE": "010000",
        "JOB_FHICL_FILE": "prod_muminus_0.1-5.0GeV_isotropic_dunevd10kt_1x8x6_3view.fcl"
      },
      "output_pattern_next_stage": "*_gen.root"
    },

    {
      "id": 2,
      "jobscript": "MCJobSubmission/g4.jobscript",
      "wall_seconds": 28800,
      "rss_mib": 8000,
      "env": {
        "JOB_FHICL_FILE": "standard_g4_dunevd10kt_1x8x6_3view_30deg.fcl"
      },
      "output_pattern_next_stage": "*_g4.root"
    },

    {
      "id": 3,
      "jobscript": "MCJobSubmission/detsim.jobscript",
      "wall_seconds": 28800,
      "rss_mib": 8000,
      "env": {
        "JOB_FHICL_FILE": "standard_detsim_dunevd10kt_1x8x6_3view_30deg.fcl"
      },
      "output_pattern_next_stage": "*_detsim.root"
    },

    {
      "id": 4,
      "jobscript": "MCJobSubmission/reco.jobscript",
      "wall_seconds": 28800,
      "rss_mib": 8000,
      "env": {
        "JOB_FHICL_FILE": "standard_supera_dunevd10kt_1x8x6_3view_30deg.fcl"
      },
      "output_patterns": [
        "*_reco.root",
        "*_larcv.root"
      ],
      "output_rse_expression": "DUNE_US_FNAL_DISK_STAGE",
      "lifetime_days": 90
    }
  ]
}

